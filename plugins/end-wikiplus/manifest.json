{
  "manifestVersion": 1,
  "id": "org.eihrteam.ipe",
  "name": "InPageEdit NEXT for Endfield Wiki⁺",
  "version": "3.1.0",
  "description": "Endfield Wiki⁺ host-first InPageEdit plugin package.",
  "entry": "dist/index.js",
  "styles": ["dist/styles.css"],
  "permissions": [
    "auth.session.read",
    "events.listen",
    "plugins.list",
    "storage.read",
    "storage.write",
    "wiki.current.read",
    "wiki.image.stage",
    "wiki.image.upload",
    "wiki.item.read",
    "wiki.me.read",
    "wiki.update-info.read",
    "wiki.item.submit",
    "wiki.draft.clear"
  ],
  "pages": ["wiki-renderer"],
  "hostCompatibility": {
    "apiVersion": 1
  }
}
